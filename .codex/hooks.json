{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/run-vp-check-fix.ts\"",
            "statusMessage": "vp check --fix"
          }
        ]
      }
    ]
  }
}
