{
  "name": "mdxg-redline",
  "version": "0.1.0",
  "description": "Inline review tool for MDXG markdown — capture highlighted comments and export them as structured JSON for LLM agents.",
  "keywords": [
    "annotations",
    "feedback",
    "human-in-the-loop",
    "inline-comments",
    "llm",
    "markdown",
    "markdown-review",
    "mdxg",
    "single-html"
  ],
  "license": "MIT",
  "author": "oubakiou",
  "bin": {
    "mdxg-redline": "dist/review-request.mjs"
  },
  "files": [
    "dist/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "build": "vp build --config vite.mermaid.config.ts && vp build --config vite.katex.config.ts && node scripts/build-katex-css.ts && vp build && vp build --config vite.review-request.config.ts",
    "build:katex": "vp build --config vite.katex.config.ts && node scripts/build-katex-css.ts",
    "build:mermaid": "vp build --config vite.mermaid.config.ts",
    "build:review-request": "vp build --config vite.review-request.config.ts",
    "build:watch": "vp build --watch",
    "dev": "vp dev",
    "test": "vp test",
    "test:watch": "vp test --watch"
  },
  "dependencies": {
    "katex": "0.x",
    "marked": "^12.0.2",
    "marked-footnote": "^1.4.0",
    "mermaid": "^11.15.0",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "^2.1.80",
    "@openai/codex": "0.x",
    "@types/node": "^24.0.0",
    "happy-dom": "^20.9.0",
    "oxlint-tsgolint": "0.x",
    "typescript": "^6.0.2",
    "typescript-language-server": "^5.3.0",
    "vite-plugin-singlefile": "^2.3.3",
    "vite-plus": "0.x",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
