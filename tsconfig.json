{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ES2022",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "vite/client", "vitest/importMeta"]
  },
  "include": [
    "src/**/*.ts",
    "vite.config.ts",
    "vite.review-request.config.ts",
    ".claude/**/*",
    ".codex/**/*"
  ],
  "exclude": ["dist", "node_modules"]
}
