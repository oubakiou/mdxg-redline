#!/bin/bash
# pre-commit hook: lint / format / type / test を走らせ、いずれか失敗したら commit を block する。
# set -e なしだと vp check --fix が非 0 で抜けても後続コマンドに進んでしまい、最後の vp test が
# pass すると hook 全体が exit 0 になって commit が通ってしまう (sort-imports などの --fix 対象外
# ルールが見落とされる経路)。set -e で最初の失敗で止める。
set -e

vp check --fix

# --fix による変更がステージされていないファイルに残っている場合、再ステージして含める
git diff --name-only --diff-filter=M | while IFS= read -r file; do
  git add "$file"
done

vp test
