/*
  Referrer-Policy: no-referrer
  X-Content-Type-Options: nosniff

/
  Content-Security-Policy: default-src 'none'; style-src 'unsafe-inline'; img-src https: data:; connect-src 'self' https://raw.githubusercontent.com https://gist.githubusercontent.com; script-src 'self' 'unsafe-inline'; base-uri 'none'; form-action 'none'
  Cache-Control: public, max-age=300

/index.html
  Content-Security-Policy: default-src 'none'; style-src 'unsafe-inline'; img-src https: data:; connect-src 'self' https://raw.githubusercontent.com https://gist.githubusercontent.com; script-src 'self' 'unsafe-inline'; base-uri 'none'; form-action 'none'
  Cache-Control: public, max-age=300

/fingerprinted/*
  Cache-Control: public, max-age=31536000, immutable

/canonical/*
  Cache-Control: public, max-age=300
